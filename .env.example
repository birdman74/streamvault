# =============================================================================
# StreamVault — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=streamvault
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# --- MongoDB Atlas ---
MONGO_ATLAS_URI=

# --- LiteLLM ---
LITELLM_MASTER_KEY=

# --- AWS (used by LiteLLM for Bedrock routing) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- TMDB API ---
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3

# --- Spring Boot ---
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# --- App ---
APP_ENV=local

